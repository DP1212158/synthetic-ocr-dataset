{
  "schema_version": "category_layout_templates.v1",
  "category_id": "newspaper_page",
  "category_cn": "报纸页",
  "renderer": "newspaper_json_renderer_v1",
  "purpose": "报纸页专用结构树模板。每个模板直接约束页面比例、区域、组件、文本密度和 QA 要求，用于驱动 HTML/CSS 生成。",
  "shared_constraints": {
    "language": "bo",
    "orientation_default": "portrait",
    "table_intensity": "none",
    "min_text_blocks": 18,
    "min_story_blocks": 6,
    "required_labels": ["document_title", "metadata", "section_title", "paragraph"],
    "forbidden_patterns": ["single_big_table", "landscape_news_card_only", "poster_like_layout", "sparse_top_heavy_layout"],
    "qa": {
      "overflow_blocks": 0,
      "out_of_bounds_blocks": 0,
      "min_tibetan_ratio": 0.35,
      "allow_cyrillic": false,
      "allow_tibetan_small_marks": false
    }
  },
  "component_defaults": {
    "masthead": {
      "labels": ["document_title", "metadata"],
      "style_role": "newspaper_identity"
    },
    "story": {
      "labels": ["section_title", "paragraph"],
      "paragraph_min_chars": 52,
      "paragraph_max_chars": 130
    },
    "brief": {
      "labels": ["list_item"],
      "paragraph_min_chars": 22,
      "paragraph_max_chars": 66
    },
    "image_box": {
      "label": "image",
      "content": ""
    }
  },
  "templates": [
    {
      "template_id": "newspaper_page_v01",
      "variant": 1,
      "template_name_cn": "传统竖版日报头版",
      "layout_family": "classic_broadsheet_frontpage",
      "prompt": "竖版传统日报头版。顶部为严肃报眉和期号日期，中部有头条新闻，主体采用三列结构：左侧头条与新闻图片，中间双栏正文，右侧短讯栏。整体应有正式报纸的黑色分割线、高文字密度和清晰阅读层级。",
      "page": {
        "width": 1240,
        "height": 1754,
        "orientation": "portrait",
        "background": "warm_newsprint"
      },
      "regions": [
        {
          "id": "masthead",
          "type": "masthead_centered",
          "position": "top",
          "height_ratio": 0.13,
          "components": [
            {"type": "kicker", "label": "metadata", "text_role": "newspaper_kicker"},
            {"type": "newspaper_name", "label": "document_title", "scale": "xxl"},
            {"type": "issue_bar", "label": "metadata", "items": ["issue_no", "date", "edition"]}
          ]
        },
        {
          "id": "main_grid",
          "type": "grid",
          "columns": [1.08, 1.22, 0.72],
          "gap": 18,
          "height_mode": "content",
          "components": [
            {"type": "lead_story", "story_count": 1, "paragraphs_per_story": 2, "include_image": true, "image_ratio": 0.58},
            {"type": "story_column", "story_count": 4, "paragraphs_per_story": 1, "columns_inside": 2},
            {"type": "brief_sidebar", "section_title": "མདོར་བསྡུས", "brief_count": 9}
          ]
        },
        {
          "id": "footer",
          "type": "newspaper_footer",
          "position": "bottom",
          "label": "footer"
        }
      ],
      "style_tokens": {
        "ink": "#171717",
        "muted": "#5f5b54",
        "line": "#222222",
        "accent": "#111111",
        "paper": "#fbf8ee",
        "font_scale": "compact",
        "rule_style": "black_rules"
      },
      "content_plan": {
        "text_density": "high",
        "story_blocks": 7,
        "brief_blocks": 14,
        "image_blocks": 1,
        "min_total_blocks": 34
      },
      "qa_constraints": {
        "must_be_portrait": true,
        "min_text_blocks": 20,
        "min_story_blocks": 5,
        "max_empty_bottom_ratio": 0.12
      }
    },
    {
      "template_id": "newspaper_page_v02",
      "variant": 2,
      "template_name_cn": "图片主导新闻版",
      "layout_family": "photo_led_news_page",
      "prompt": "图片主导的报纸新闻版。顶部为报头，页面上半部由大幅新闻图片和头条标题构成，右侧是两条重点短新闻；下半部为三栏正文和底部快讯条。整体仍像报纸版面，不是海报或宣传单。",
      "page": {
        "width": 1240,
        "height": 1754,
        "orientation": "portrait",
        "background": "clean_newsprint"
      },
      "regions": [
        {
          "id": "masthead",
          "type": "masthead_split",
          "position": "top",
          "height_ratio": 0.1,
          "components": [
            {"type": "newspaper_name", "label": "document_title", "scale": "xl"},
            {"type": "issue_bar", "label": "metadata", "items": ["date", "page_no", "section"]}
          ]
        },
        {
          "id": "hero_zone",
          "type": "asymmetric_grid",
          "columns": [1.55, 0.8],
          "height_ratio": 0.36,
          "components": [
            {"type": "photo_lead", "include_image": true, "headline_scale": "xl", "caption": true, "paragraphs": 1},
            {"type": "stacked_side_stories", "story_count": 2, "paragraphs_per_story": 1}
          ]
        },
        {
          "id": "body_columns",
          "type": "multi_column_zone",
          "columns": 3,
          "story_count": 5,
          "paragraphs_per_story": 1,
          "height_mode": "fill_remaining"
        },
        {
          "id": "bottom_briefs",
          "type": "brief_strip",
          "position": "bottom",
          "brief_count": 5
        }
      ],
      "style_tokens": {
        "ink": "#202020",
        "muted": "#666666",
        "line": "#303030",
        "accent": "#2f4e5f",
        "paper": "#fffdf5",
        "font_scale": "regular",
        "rule_style": "double_header_rule"
      },
      "content_plan": {
        "text_density": "medium_high",
        "story_blocks": 10,
        "brief_blocks": 6,
        "image_blocks": 1,
        "min_total_blocks": 30
      },
      "qa_constraints": {
        "must_be_portrait": true,
        "min_text_blocks": 18,
        "max_image_blocks": 1,
        "forbid_poster_like_hero_only": true
      }
    },
    {
      "template_id": "newspaper_page_v03",
      "variant": 3,
      "template_name_cn": "密集四栏日报",
      "layout_family": "dense_four_column_daily",
      "prompt": "文字密集的四栏日报。报头紧凑，页面主体由四列新闻组成，每列包含多个小标题和短段落；页面中间可穿插一个很小的图片或公告块，底部有横向快讯。整体重点是高文本密度。",
      "page": {
        "width": 1240,
        "height": 1754,
        "orientation": "portrait",
        "background": "warm_newsprint"
      },
      "regions": [
        {
          "id": "compact_masthead",
          "type": "masthead_compact",
          "position": "top",
          "height_ratio": 0.095,
          "components": [
            {"type": "section_label", "label": "metadata", "text_role": "daily_news"},
            {"type": "newspaper_name", "label": "document_title", "scale": "xl"},
            {"type": "issue_bar", "label": "metadata", "items": ["issue_no", "date"]}
          ]
        },
        {
          "id": "dense_columns",
          "type": "strict_columns",
          "columns": 4,
          "gap": 15,
          "story_count": 12,
          "paragraphs_per_story": 1,
          "include_micro_ad": true,
          "micro_ad_position": "column_3_middle"
        },
        {
          "id": "ticker",
          "type": "brief_strip",
          "position": "bottom",
          "brief_count": 6
        }
      ],
      "style_tokens": {
        "ink": "#1b1b1b",
        "muted": "#5e5e5a",
        "line": "#44413a",
        "accent": "#3a3a36",
        "paper": "#f9f5e8",
        "font_scale": "small_dense",
        "rule_style": "thin_column_rules"
      },
      "content_plan": {
        "text_density": "very_high",
        "story_blocks": 18,
        "brief_blocks": 8,
        "image_blocks": 0,
        "min_total_blocks": 40
      },
      "qa_constraints": {
        "must_be_portrait": true,
        "min_text_blocks": 28,
        "min_column_count": 4,
        "max_empty_bottom_ratio": 0.08
      }
    },
    {
      "template_id": "newspaper_page_v04",
      "variant": 4,
      "template_name_cn": "社区校园小报",
      "layout_family": "community_bulletin_newspaper",
      "prompt": "社区或校园小报。报头较活泼，主体包含公告栏、短新闻、活动日历、联系信息和小广告块。页面结构应该像信息服务型小报，不能像普通公告通知或表单。",
      "page": {
        "width": 1240,
        "height": 1754,
        "orientation": "portrait",
        "background": "light_notice_paper"
      },
      "regions": [
        {
          "id": "community_header",
          "type": "masthead_banner",
          "position": "top",
          "height_ratio": 0.12,
          "components": [
            {"type": "newspaper_name", "label": "document_title", "scale": "xl"},
            {"type": "community_meta", "label": "metadata", "items": ["date", "area", "contact"]}
          ]
        },
        {
          "id": "community_grid",
          "type": "masonry_grid",
          "columns": [1.0, 1.0, 0.78],
          "components": [
            {"type": "notice_board", "item_count": 5, "section_title": "བརྡ་ཁྱབ"},
            {"type": "short_news_stack", "story_count": 4, "paragraphs_per_story": 1},
            {"type": "calendar_box", "item_count": 5},
            {"type": "contact_box", "item_count": 3},
            {"type": "small_ad_box", "item_count": 3}
          ]
        },
        {
          "id": "bottom_strip",
          "type": "brief_strip",
          "position": "bottom",
          "brief_count": 4
        }
      ],
      "style_tokens": {
        "ink": "#22302c",
        "muted": "#64716d",
        "line": "#9eb2aa",
        "accent": "#2f6b58",
        "paper": "#fcfff8",
        "font_scale": "regular",
        "rule_style": "soft_boxes"
      },
      "content_plan": {
        "text_density": "medium_high",
        "story_blocks": 6,
        "brief_blocks": 16,
        "image_blocks": 0,
        "min_total_blocks": 32
      },
      "qa_constraints": {
        "must_be_portrait": true,
        "must_not_look_like_form": true,
        "min_distinct_regions": 5
      }
    },
    {
      "template_id": "newspaper_page_v05",
      "variant": 5,
      "template_name_cn": "专题特刊版",
      "layout_family": "special_feature_edition",
      "prompt": "专题特刊报纸页。顶部有专题标识和报头，中部为专题主标题、摘要和主文；侧边有时间线、人物或机构信息框，底部有延伸阅读。整体应像报纸特刊，而不是杂志封面或报告页。",
      "page": {
        "width": 1240,
        "height": 1754,
        "orientation": "portrait",
        "background": "feature_newsprint"
      },
      "regions": [
        {
          "id": "feature_header",
          "type": "special_masthead",
          "position": "top",
          "height_ratio": 0.14,
          "components": [
            {"type": "special_label", "label": "metadata", "text_role": "special_issue"},
            {"type": "newspaper_name", "label": "document_title", "scale": "xl"},
            {"type": "issue_bar", "label": "metadata", "items": ["date", "topic", "page_no"]}
          ]
        },
        {
          "id": "feature_body",
          "type": "asymmetric_feature",
          "columns": [1.35, 0.75],
          "components": [
            {"type": "feature_main_story", "headline_scale": "xxl", "lead_paragraph": true, "story_count": 1, "paragraphs_per_story": 4},
            {"type": "timeline_sidebar", "item_count": 6},
            {"type": "fact_box", "item_count": 4}
          ]
        },
        {
          "id": "related_reading",
          "type": "related_strip",
          "position": "bottom",
          "item_count": 4
        }
      ],
      "style_tokens": {
        "ink": "#211f1c",
        "muted": "#6b6258",
        "line": "#8f8170",
        "accent": "#8a4c2a",
        "paper": "#fff9ee",
        "font_scale": "feature",
        "rule_style": "strong_accent"
      },
      "content_plan": {
        "text_density": "medium_high",
        "story_blocks": 9,
        "brief_blocks": 14,
        "image_blocks": 0,
        "min_total_blocks": 36
      },
      "qa_constraints": {
        "must_be_portrait": true,
        "must_include_sidebar": true,
        "must_not_look_like_magazine_cover": true
      }
    },
    {
      "template_id": "newspaper_page_v06",
      "variant": 6,
      "template_name_cn": "现代新闻摘要小报",
      "layout_family": "modern_digest_newspaper",
      "prompt": "现代新闻摘要小报。顶部是简洁报头和日期，主体由一个主新闻卡片、多个新闻摘要块、右侧快讯栏和底部横条组成。可以有边框和浅色底，但必须保持报纸新闻密度，不能变成普通卡片文档。",
      "page": {
        "width": 1240,
        "height": 1754,
        "orientation": "portrait",
        "background": "clean_modern_paper"
      },
      "regions": [
        {
          "id": "modern_header",
          "type": "masthead_minimal",
          "position": "top",
          "height_ratio": 0.11,
          "components": [
            {"type": "newspaper_name", "label": "document_title", "scale": "xl"},
            {"type": "issue_bar", "label": "metadata", "items": ["date", "section", "issue_no"]}
          ]
        },
        {
          "id": "digest_grid",
          "type": "digest_layout",
          "columns": [1.25, 1.0, 0.72],
          "components": [
            {"type": "primary_digest_story", "paragraphs": 2, "include_image": true, "image_ratio": 0.42},
            {"type": "digest_cards", "card_count": 5, "paragraphs_per_card": 1},
            {"type": "brief_sidebar", "section_title": "མྱུར་འཕྲིན", "brief_count": 8}
          ]
        },
        {
          "id": "stats_footer",
          "type": "metric_strip",
          "position": "bottom",
          "item_count": 4
        }
      ],
      "style_tokens": {
        "ink": "#202326",
        "muted": "#626a71",
        "line": "#b8bec6",
        "accent": "#2d6276",
        "paper": "#fffefa",
        "font_scale": "modern",
        "rule_style": "light_grid"
      },
      "content_plan": {
        "text_density": "medium",
        "story_blocks": 8,
        "brief_blocks": 14,
        "image_blocks": 1,
        "min_total_blocks": 32
      },
      "qa_constraints": {
        "must_be_portrait": true,
        "min_text_blocks": 22,
        "must_not_be_single_template_cards": true,
        "max_empty_bottom_ratio": 0.12
      }
    }
  ]
}
