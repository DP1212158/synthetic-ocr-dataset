      },
      "points": null,
      "block_label": "document_title",
      "block_content": "기회로 하늘에서 베이징을",
      "is_text": true,
      "order": "2",
      "attributes": {
        "tag": "div",
        "row": null,
        "col": null,
        "font_size": "37px",
        "font_family": "\"Apple SD Gothic Neo\", \"Arial Unicode\", sans-serif",
        "is_text": true,
