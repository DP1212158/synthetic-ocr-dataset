    },
    {
      "block_id": "05_book_page_json_01_b0004",
      "coordinates": {
        "x_min": 28.42,
        "y_min": 178.59,
        "x_max": 562.82,
        "y_max": 260.93
      },
      "points": null,
      "block_label": "paragraph",
      "block_content": "자신이 약해져도 괜찮고 쉬어도 됩니다. 감정은 자신에게 돌려주고, 시간은 좋아하는 일에 쓰세요. 먼저 마음을 챙기고 세상을 안아주세요. 진정한 강함은 자신을 받아들이고 존중하는",
      "is_text": true,
      "order": "3",
      "attributes": {
        "tag": "div",
        "row": null,
        "col": null,
        "font_size": "18px",
        "font_family": "\"Apple SD Gothic Neo\", \"Arial Unicode\", sans-serif",
        "is_text": true,
        "asset_id": null,
        "asset_source": null,
        "asset_crop": null
      },
      "reading_order": 4,
      "reading_group": "body",
      "reading_role": "paragraph",
      "reading_order_confidence": "medium"
    },
    {
      "block_id": "05_book_page_json_01_b0005",
      "coordinates": {
        "x_min": 29.32,
        "y_min": 263.12,
        "x_max": 563.99,
        "y_max": 370.99
      },
      "points": null,
      "block_label": "paragraph",
      "block_content": "이 길을 따라 도착한 곳에서 바라보는 성산일출봉은 정면에서 보는 것과는 다른 맛이 있었다. 그리고 일출봉 주차장을 지나 광치기 해안에 도착하면 15 올레의 첫 관문을 무사히 통과하게 된다. 이렇게 성산일출봉 아래 광치기 해변에서 올레 1코스는 끝이 났다. 하지만 끝은 새로",
      "is_text": true,
      "order": "4",
      "attributes": {
        "tag": "div",
        "row": null,
        "col": null,
        "font_size": "18px",
        "font_family": "\"Apple SD Gothic Neo\", \"Arial Unicode\", sans-serif",
        "is_text": true,
        "asset_id": null,
        "asset_source": null,
        "asset_crop": null
      },
      "reading_order": 7,
      "reading_group": "body",
      "reading_role": "paragraph",
      "reading_order_confidence": "medium"
    },
    {
      "block_id": "05_book_page_json_01_b0006",
      "coordinates": {
        "x_min": 30.5,
        "y_min": 373.19,
        "x_max": 565.17,
        "y_max": 481.17
      },
      "points": null,
      "block_label": "paragraph",
      "block_content": "실은 아비는 참으로 고마운 인생을 살았다고 생각한다. 어려운 시절, 빈농의 장남으로 태어나 외갓집 외할머니 슬하에서 어린 시절을 보내고 조금은 비뚤어진 성격으로 성장했지만 운 좋게도 교사가 되었고 시인이 되어서 두 가지 일을 함께하면서 살았다고 생각한다.",
      "is_text": true,
      "order": "5",
      "attributes": {
        "tag": "div",
        "row": null,
        "col": null,
        "font_size": "18px",
        "font_family": "\"Apple SD Gothic Neo\", \"Arial Unicode\", sans-serif",
        "is_text": true,
        "asset_id": null,
        "asset_source": null,
        "asset_crop": null
      },
      "reading_order": 9,
      "reading_group": "body",
      "reading_role": "paragraph",
      "reading_order_confidence": "medium"
    },
    {
      "block_id": "05_book_page_json_01_b0007",
      "coordinates": {
        "x_min": 31.67,
        "y_min": 483.36,
        "x_max": 566.34,
        "y_max": 591.24
      },
      "points": null,
      "block_label": "paragraph",
      "block_content": "얼마 뒤 두 사람은 아파트 승강기에서 내려 오대표 집 앞에 섰다.성민이 주소를 한번 더 꼼꼼히 확인한 뒤 한 손으로 초인종을 꼭 눌렀다.잠시 후 반쯤 열린 현관문 사이로 오대표의 모습이 보였다. 세련된 옆 가르다 보다 단발에 서글서글한 눈매를 가진 중년여성이었다.",
      "is_text": true,
      "order": "6",
      "attributes": {
        "tag": "div",
        "row": null,
        "col": null,
        "font_size": "18px",
        "font_family": "\"Apple SD Gothic Neo\", \"Arial Unicode\", sans-serif",
        "is_text": true,
        "asset_id": null,
        "asset_source": null,
        "asset_crop": null
      },
      "reading_order": 11,
      "reading_group": "body",
      "reading_role": "paragraph",
      "reading_order_confidence": "medium"
    },
    {
      "block_id": "05_book_page_json_01_b0008",
      "coordinates": {
        "x_min": 32.85,
        "y_min": 593.43,
        "x_max": 567.25,
        "y_max": 675.76
      },
      "points": null,
      "block_label": "paragraph",
      "block_content": "외롭다고 아무나 만나면 아무 연애나 하다가 아무 이별을 하게 됩니다. 외로울 때가 아니라 사랑하는 사람이 생겼을 때 연애하세요. 연애가 내 인생의 외로움을 해결해주지는 않습니다",
      "is_text": true,
      "order": "7",
      "attributes": {
        "tag": "div",
        "row": null,
        "col": null,
        "font_size": "18px",
        "font_family": "\"Apple SD Gothic Neo\", \"Arial Unicode\", sans-serif",
        "is_text": true,
        "asset_id": null,
        "asset_source": null,
        "asset_crop": null
      },
      "reading_order": 13,
      "reading_group": "body",
      "reading_role": "paragraph",
      "reading_order_confidence": "medium"
    },
    {
      "block_id": "05_book_page_json_01_b0009",
      "coordinates": {
        "x_min": 33.75,
        "y_min": 677.96,
        "x_max": 568.15,
        "y_max": 760.29
      },
      "points": null,
      "block_label": "paragraph",
      "block_content": "일관성과 다양성 …… 80 논문마다 참고문헌 작성 형식이 같은가요? 15 참고문헌의 배열 순서 …… 84 자료 배열 순서가 따로 있어요? 16 참고문헌 목록 작성 연습 ……",
      "is_text": true,
      "order": "8",
      "attributes": {
        "tag": "div",
        "row": null,
        "col": null,
        "font_size": "18px",
        "font_family": "\"Apple SD Gothic Neo\", \"Arial Unicode\", sans-serif",
        "is_text": true,
        "asset_id": null,
        "asset_source": null,
        "asset_crop": null
      },
      "reading_order": 15,
      "reading_group": "body",
      "reading_role": "paragraph",
      "reading_order_confidence": "medium"
    },
    {
      "block_id": "05_book_page_json_01_b0010",
      "coordinates": {
        "x_min": 34.65,
        "y_min": 762.48,
        "x_max": 569.32,
        "y_max": 870.45
      },
      "points": null,
      "block_label": "paragraph",
      "block_content": "또 다른 길을 찾을 것인가. 나는 다른 길을 찾기로 했다. 길을 잃었다고 낙심할 이유가 없다. 사실 길을 잃은 것은 행운이다. 정해진 길이 아니라 나만의 올레길을 만들어 볼 수 있는 기회가 생겼으니까. 제주 한 곳에 아무도 모르는 나만의 올레길을 갖는다는 것은 또 얼마나 행복한 일인가.",
      "is_text": true,
      "order": "9",
      "attributes": {
        "tag": "div",
        "row": null,
        "col": null,
        "font_size": "18px",
        "font_family": "\"Apple SD Gothic Neo\", \"Arial Unicode\", sans-serif",
        "is_text": true,
        "asset_id": null,
        "asset_source": null,
        "asset_crop": null
      },
      "reading_order": 17,
      "reading_group": "body",
      "reading_role": "paragraph",
      "reading_order_confidence": "medium"
    },
    {
      "block_id": "05_book_page_json_01_b0011",
      "coordinates": {
        "x_min": 35.83,
        "y_min": 872.65,
        "x_max": 570.23,
        "y_max": 954.98
      },
      "points": null,
      "block_label": "paragraph",
      "block_content": "중심 내용 파악하기: 학생 는 활동 자료를 글로 읽을 때와 말로 들을 때 모두 중심 내용을 파악하지 못하였다. 학생 는 활동 자료를 글로 읽을 때는 중심 내용을 파악하지 못했지만 말로 들을 때는 중심 내용을 파악하였다.",
      "is_text": true,
      "order": "10",
      "attributes": {
        "tag": "div",
        "row": null,
        "col": null,
        "font_size": "18px",
        "font_family": "\"Apple SD Gothic Neo\", \"Arial Unicode\", sans-serif",
