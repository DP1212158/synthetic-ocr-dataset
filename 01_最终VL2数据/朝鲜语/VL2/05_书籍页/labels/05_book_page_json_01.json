    },
    {
      "block_id": "05_book_page_json_01_b0013",
      "coordinates": {
        "x_min": 37.63,
        "y_min": 1041.7,
        "x_max": 572.03,
        "y_max": 1124.04
      },
      "points": null,
      "block_label": "paragraph",
      "block_content": "아니었지만 머리가 복잡해질 때면 가만히 종이를 바라보게 되었다. 눈에 보이는 글자를 천천히 따라 읽는것만으로도 머리가 가벼워졌다. 마음이 시끄러울 때도, 일이 잘 풀리지 않을",
      "is_text": true,
      "order": "12",
      "attributes": {
        "tag": "div",
        "row": null,
        "col": null,
        "font_size": "18px",
        "font_family": "\"Apple SD Gothic Neo\", \"Arial Unicode\", sans-serif",
