      "reading_order_confidence": "medium"
    },
    {
      "block_id": "05_book_page_json_01_b0022",
      "coordinates": {
        "x_min": 601.23,
        "y_min": 705.34,
        "x_max": 1135.63,
        "y_max": 787.67
      },
      "points": null,
      "block_label": "paragraph",
      "block_content": "속수무책으로 쓰러져 있는 한나를 죽도록 폈다. 손바닥으로 한나의 뺨을 수차례 때리고, 어깨와 가슴을 두 주먹으로 광황 내려졌다. 어른들이 말려도 멈추지 않았다. 지쳐 쓰러지기",
      "is_text": true,
      "order": "21",
      "attributes": {
        "tag": "div",
        "row": null,
        "col": null,
        "font_size": "18px",
        "font_family": "\"Apple SD Gothic Neo\", \"Arial Unicode\", sans-serif",
        "is_text": true,
        "asset_id": null,
