      "coordinates": {
        "x_min": 36.73,
        "y_min": 957.18,
        "x_max": 571.13,
        "y_max": 1039.51
      },
      "points": null,
      "block_label": "paragraph",
      "block_content": "무거운줄 알았다면 일년 삼백육십오일 신어야 하는 그 구두를 조금은 천천히 신을걸 그랬나보다. 어린아이였을땐 빨리 어른이 되고 싶고 어른이 되어선 어려보이려고 노력하고 자신에게",
      "is_text": true,
      "order": "11",
      "attributes": {
        "tag": "div",
        "row": null,
        "col": null,
        "font_size": "18px",
        "font_family": "\"Apple SD Gothic Neo\", \"Arial Unicode\", sans-serif",
        "is_text": true,
        "asset_id": null,
