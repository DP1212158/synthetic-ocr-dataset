    {
      "block_id": "05_book_page_json_01_b0017",
      "coordinates": {
        "x_min": 596.44,
        "y_min": 257.06,
        "x_max": 1130.85,
        "y_max": 339.4
      },
      "points": null,
      "block_label": "paragraph",
      "block_content": "예를 들면, 아침 출근길 하늘은 맑고 가로수에는 햇빛이 비칠때, 적당히 선선하고, 기분 좋은 바람이 불어올 때, 때마침 도착한 버스에 운 좋게 앉을 자리가 있을 때, 좋은 사람과",
      "is_text": true,
      "order": "16",
      "attributes": {
        "tag": "div",
        "row": null,
        "col": null,
        "font_size": "18px",
        "font_family": "\"Apple SD Gothic Neo\", \"Arial Unicode\", sans-serif",
        "is_text": true,
        "asset_id": null,
