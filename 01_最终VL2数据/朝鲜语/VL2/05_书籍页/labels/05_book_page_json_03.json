    },
    {
      "block_id": "05_book_page_json_03_b0038",
      "coordinates": {
        "x_min": 464.22,
        "y_min": 112.74,
        "x_max": 821.57,
        "y_max": 231.74
      },
      "points": null,
      "block_label": "paragraph",
      "block_content": "대상인 객체로 규정하고 그 법칙을 파악하여 인간이 자신의 의도에 따라 착취하거나 조작하고자 하는 서구 근대 세계관이 한국에 유입되면서 나타났다. 이러한",
      "is_text": true,
      "order": "11",
      "attributes": {
        "tag": "div",
        "row": null,
        "col": null,
        "font_size": "18px",
        "font_family": "\"Apple SD Gothic Neo\", \"Arial Unicode\", sans-serif",
        "is_text": true,
        "asset_id": null,
        "asset_source": null,
