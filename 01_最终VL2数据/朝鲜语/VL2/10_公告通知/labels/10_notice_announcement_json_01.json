        "x_max": 1177.86,
        "y_max": 186.68
      },
      "points": null,
      "block_label": "paragraph",
      "block_content": "새로울 뿐이란다. 그러하니 죽음의 날에도 나는 그저 모든 것에 감사하고 모든 사람들에게 고마운 마음을 갖기를 소망한다. 나 떠나는",
      "is_text": true,
      "order": "2",
      "attributes": {
        "tag": "div",
        "row": null,
        "col": null,
        "font_size": "20px",
        "font_family": "\"Apple SD Gothic Neo\", \"Arial Unicode\", sans-serif",
        "is_text": true,
        "asset_id": null,
        "asset_source": null,
        "asset_crop": null
      },
      "reading_order": 3,
      "reading_group": "body",
