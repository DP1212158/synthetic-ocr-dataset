      },
      "reading_order": 14,
      "reading_group": "body",
      "reading_role": "paragraph",
      "reading_order_confidence": "medium"
    },
    {
      "block_id": "10_notice_announcement_json_01_b0015",
      "coordinates": {
        "x_min": 42.79,
        "y_min": 674.71,
        "x_max": 1174.33,
        "y_max": 739.9
      },
      "points": null,
      "block_label": "paragraph",
      "block_content": "과거는 시간을 통과하면서 매번 다른 모습이 된다. 기억들은 계속 변화한다. 하지만 내 이야기에는 바뀌지 않는 단 하나의 사건이 있고, 나는 그것을 빈틈없이 헤아리고 싶다.",
      "is_text": true,
      "order": "14",
      "attributes": {
        "tag": "div",
        "row": null,
        "col": null,
        "font_size": "20px",
        "font_family": "\"Apple SD Gothic Neo\", \"Arial Unicode\", sans-serif",
        "is_text": true,
